-using ScopedHandle = ScopedResource<INVALID_HANDLE_VALUE, close_handle>;
+// INVALID_HANDLE_VALUE is ((HANDLE)-1). MSVC accepts it as a non-type template
+// argument, but standard C++ forbids a reinterpret-cast pointer there, so Clang
+// (clang-cl and mingw alike) rejects ScopedResource<INVALID_HANDLE_VALUE, ...>.
+// Use a dedicated RAII class that only references the sentinel at runtime.
+class ScopedHandle {
+  HANDLE val_;
+
+ public:
+  explicit ScopedHandle(HANDLE v) : val_(v) {}
+  ~ScopedHandle() {
+    if (val_ != INVALID_HANDLE_VALUE) {
+      close_handle(val_);
+    }
+  }
+  HANDLE get() const {
+    return val_;
+  }
+  HANDLE release() {
+    HANDLE tmp = val_;
+    val_ = INVALID_HANDLE_VALUE;
+    return tmp;
+  }
+  ScopedHandle(const ScopedHandle&) = delete;
+  ScopedHandle& operator=(const ScopedHandle&) = delete;
+};
 #endif
 
